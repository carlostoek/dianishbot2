# Copia este archivo a .env y rellena los valores
BOT_TOKEN=your_telegram_bot_token

# Proveedor LLM: deepseek (default) o anthropic
LLM_PROVIDER=deepseek
DEEPSEEK_KEY=your_deepseek_api_key

# Solo si LLM_PROVIDER=anthropic
ANTHROPIC_KEY=your_anthropic_api_key
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Para el extractor.py (acceso a nivel usuario con Telethon)
# Obtené API_ID y API_HASH gratis en https://my.telegram.org
API_ID=your_api_id
API_HASH=your_api_hash